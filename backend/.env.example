# Firebase Admin SDK
FIREBASE_CREDENTIALS_PATH=./firebase_credentials.json
FIREBASE_PROJECT_ID=your-firebase-project-id

# App settings
APP_SECRET_KEY=your-super-secret-key-here
DEBUG=True

# AI Model (optional: use openai alternative)
OPENAI_API_KEY=your-openai-api-key-optional

# OpenRouter (used by chatbot, job/course matching, weekly plan)
OPENROUTER_API_KEY=your-openrouter-api-key
# Example models: openai/gpt-4o-mini, anthropic/claude-3.5-sonnet
OPENROUTER_MODEL=openai/gpt-4o-mini
# Optional headers recommended by OpenRouter
OPENROUTER_SITE_URL=http://localhost:8000
OPENROUTER_APP_NAME=NaviUdan

# Google Gemini (chatbot, job/course matching, weekly plan). Copy to .env — never commit real keys.
GEMINI_API_KEY=your-gemini-api-key
# Optional: gemini-2.0-flash, gemini-1.5-flash, etc.
GEMINI_MODEL=gemini-2.0-flash
